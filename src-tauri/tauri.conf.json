{
  "productName": "CCResDoc",
  "version": "0.1.0",
  "identifier": "com.takazudo.ccresdoc",
  "build": {
    "frontendDist": "./frontend",
    "beforeBuildCommand": "cd ../app && pnpm install && pnpm exec zfb build",
    "devUrl": "http://localhost:4892/"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../app/**/*"],
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
