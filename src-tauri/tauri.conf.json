{
  "productName": "CCResDoc",
  "version": "0.1.0",
  "identifier": "com.takazudo.ccresdoc",
  "build": {
    "frontendDist": "./frontend",
    "beforeBuildCommand": ": \"${ZFB_HOME:=$HOME/repos/myoss/zfb}\" && cd ../app && ZFB_ESBUILD_BIN=\"$ZFB_HOME/crates/zfb/binaries/esbuild/esbuild\" ZFB_TAILWIND_BIN=\"$ZFB_HOME/crates/zfb/binaries/tailwindcss-v4\" zfb build",
    "devUrl": "http://localhost:4892/"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": ["../app/dist/**/*"],
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
